{
  "name": "arcovia-sourcing",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "description": "Arcovia sourcing automation for Shopify paid deposit orders.",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test",
    "test:dry-run": "node scripts/dry-run-paid-order.js",
    "worker:codex": "node scripts/local-codex-worker.js",
    "worker:codex:once": "node scripts/local-codex-worker.js --once"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1085.0"
  }
}

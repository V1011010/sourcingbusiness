PORT=8787
PUBLIC_BASE_URL=https://your-public-webhook-url.example

# Shopify Flow secret: create any long random value and use it in Flow header X-Arcovia-Flow-Secret.
ARCOVIA_FLOW_SECRET=change-me-long-random-secret
# Optional separate secret used only by the final-balance Shopify Flow.
ARCOVIA_FINAL_FLOW_SECRET=

# Shopify native webhook secret. Only needed if you subscribe ORDERS_PAID directly instead of Shopify Flow.
SHOPIFY_WEBHOOK_SECRET=

# Recommended: lets the backend fetch the full paid order from Shopify
# when Flow does not include all line-item custom fields in its HTTP body.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Dev Dashboard apps should use client credentials; the backend refreshes the
# short-lived Admin API access token automatically.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Legacy admin-created apps can still provide a static token instead.
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your_admin_api_token
SHOPIFY_ADMIN_API_VERSION=2026-04
# Requires read_orders, read_draft_orders, and write_draft_orders. When enabled,
# verified final quotes use Shopify checkout (and its configured PayFast method).
SHOPIFY_FINAL_CHECKOUT_ENABLED=true

# Optional admin diagnostics endpoint:
# GET /admin/jobs with header X-Arcovia-Admin-Secret: this-value
ARCOVIA_ADMIN_STATUS_SECRET=

# Optional persistent storage directory. On Render, point this to a mounted persistent disk path.
ARCOVIA_DATA_DIR=
# Safety override for local/sandbox testing only. Do not enable for live customer payments.
ARCOVIA_ALLOW_TEMP_PAYMENT_STORAGE=false

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_OUTPUT_TOKENS=12000
OPENAI_REASONING_EFFORT=low
OPENAI_WEB_SEARCH_CONTEXT_SIZE=high

# Email sender. Production on Render Free should use the Amazon SES HTTPS API
# because free web services block outbound SMTP ports.
EMAIL_PROVIDER=ses
# Free always-on local Gmail API option: run `npm run email:gmail:authorize` once.
# EMAIL_PROVIDER=gmail
# GOOGLE_OAUTH_CLIENT_PATH=C:/Users/you/.arcovia/google-oauth-client.json
# GOOGLE_OAUTH_TOKEN_PATH=C:/Users/you/.arcovia/google-oauth-token.json
# GMAIL_USER=arcovia.africa@gmail.com
# GMAIL_FROM_EMAIL=Arcovia <arcovia.africa@gmail.com>
FROM_EMAIL=Arcovia <updates@arcovia.africa>
ADMIN_EMAIL=vutlharingobeni5@gmail.com
REPLY_TO_EMAIL=arcovia.africa@gmail.com
EMAIL_ADMIN_RELAY_ON_FAILURE=true
EMAIL_OUTBOX_COUNTS_AS_SENT=false

# Recommended production email: Amazon SES SMTP, eu-west-1 / Ireland.
SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=Arcovia <updates@arcovia.africa>
AWS_SES_REGION=eu-west-1
AWS_SES_DOMAIN=arcovia.africa
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed when using temporary AWS credentials.
AWS_SESSION_TOKEN=

# Optional legacy fallback only. Keep EMAIL_PROVIDER=smtp for production SES.
RESEND_API_KEY=
RESEND_TEST_FROM_EMAIL=Arcovia <onboarding@resend.dev>

# PayFast final product-balance payments. Keep sandbox true until live credentials are verified.
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
PAYFAST_EMAIL_CONFIRMATION=false
PAYFAST_CONFIRMATION_EMAIL=vutlharingobeni5@gmail.com

# Customer update cadence
UPDATE_INTERVAL_HOURS=6
MAX_SOURCING_DAYS=14
DEEP_RESEARCH_MAX_ATTEMPTS=3
DEEP_RESEARCH_NO_MATCH_RETRIES=2
DEEP_RESEARCH_CONFIRMATION_CHECKS_AFTER_FOUND=2
# How often to do the next deep research pass when no supplier has been selected yet.
RESEARCH_RETRY_DELAY_MINUTES=5
# Technical API errors such as rate limits retry sooner and do not count as one of the sourcing checks.
RESEARCH_TECHNICAL_RETRY_DELAY_MINUTES=15
DEEP_RESEARCH_MAX_CANDIDATES=25
HIGH_TRUST_THRESHOLD=75
MEDIUM_TRUST_THRESHOLD=60

# Optional: use the always-on local computer + Codex CLI instead of hosted OpenAI API research.
LOCAL_CODEX_WORKER_ENABLED=true
# Runs several focused local Codex sourcing agents and merges their reports before submitting.
LOCAL_CODEX_MULTI_AGENT_ENABLED=true
# Keep this modest so the always-on PC is not overloaded.
LOCAL_CODEX_AGENT_CONCURRENCY=2
# If blank, ARCOVIA_FLOW_SECRET is used for local worker authentication.
ARCOVIA_LOCAL_WORKER_SECRET=
LOCAL_CODEX_WORKER_LEASE_MINUTES=20
DEPOSIT_SKU=ARC-DEPOSIT-250,ARC-SOURCE-250

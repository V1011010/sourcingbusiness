PORT=8787
PUBLIC_BASE_URL=https://your-public-webhook-url.example

# Shopify Flow secret: create any long random value and use it in Flow header X-Arcovia-Flow-Secret.
ARCOVIA_FLOW_SECRET=change-me-long-random-secret

# Shopify native webhook secret. Only needed if you subscribe ORDERS_PAID directly instead of Shopify Flow.
SHOPIFY_WEBHOOK_SECRET=

# Recommended: lets the backend fetch the full paid order from Shopify
# when Flow does not include all line-item custom fields in its HTTP body.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your_admin_api_token
SHOPIFY_ADMIN_API_VERSION=2026-04

# Optional admin diagnostics endpoint:
# GET /admin/jobs with header X-Arcovia-Admin-Secret: this-value
ARCOVIA_ADMIN_STATUS_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_OUTPUT_TOKENS=12000
OPENAI_REASONING_EFFORT=low
OPENAI_WEB_SEARCH_CONTEXT_SIZE=high

# Email sender. If missing, emails are written to data/outbox.json instead of sent.
RESEND_API_KEY=
FROM_EMAIL=Arcovia <updates@arcovia.africa>
ADMIN_EMAIL=vutlharingobeni5@gmail.com

# Customer update cadence
UPDATE_INTERVAL_HOURS=6
MAX_SOURCING_DAYS=14
DEEP_RESEARCH_MAX_ATTEMPTS=4
DEEP_RESEARCH_NO_MATCH_RETRIES=2
DEEP_RESEARCH_CONFIRMATION_CHECKS_AFTER_FOUND=1
# How often to do the next deep research pass when no supplier has been selected yet.
RESEARCH_RETRY_DELAY_MINUTES=5
# Technical API errors such as rate limits retry sooner and do not count as one of the sourcing checks.
RESEARCH_TECHNICAL_RETRY_DELAY_MINUTES=15
DEEP_RESEARCH_MAX_CANDIDATES=25
HIGH_TRUST_THRESHOLD=75
MEDIUM_TRUST_THRESHOLD=60

# Optional: use the always-on local computer + Codex CLI instead of hosted OpenAI API research.
LOCAL_CODEX_WORKER_ENABLED=false
# If blank, ARCOVIA_FLOW_SECRET is used for local worker authentication.
ARCOVIA_LOCAL_WORKER_SECRET=
LOCAL_CODEX_WORKER_LEASE_MINUTES=45
DEPOSIT_SKU=ARC-DEPOSIT-250,ARC-SOURCE-250

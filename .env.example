PORT=8787
PUBLIC_BASE_URL=https://your-public-webhook-url.example

# Shopify Flow secret: create any long random value and use it in Flow header X-Arcovia-Flow-Secret.
ARCOVIA_FLOW_SECRET=change-me-long-random-secret

# Shopify native webhook secret. Only needed if you subscribe ORDERS_PAID directly instead of Shopify Flow.
SHOPIFY_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Email sender. If missing, emails are written to data/outbox.json instead of sent.
RESEND_API_KEY=
FROM_EMAIL=Arcovia <updates@arcovia.africa>
ADMIN_EMAIL=vutlharingobeni5@gmail.com

# Customer update cadence
UPDATE_INTERVAL_HOURS=6
MAX_SOURCING_DAYS=14
HIGH_TRUST_THRESHOLD=75
MEDIUM_TRUST_THRESHOLD=60
DEPOSIT_SKU=ARC-SOURCE-250
